<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:layoutDirection="ltr">



    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="24dp"

        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_back" />

    <ImageButton
        android:id="@+id/btn_edit"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="24dp"
        android:layout_alignParentEnd="true"
        android:src="@drawable/ic_edit"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_edit" />


    <ImageView
        android:id="@+id/img_avatar"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_below="@id/btn_back"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="7dp"
        android:src="@drawable/ic_avatar_placeholder"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        android:contentDescription="@string/cd_avatar" />

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/img_avatar"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="11dp"
        android:text="@string/user_name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/tv_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_name"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="3dp"
        android:text="@string/user_location"
        android:textSize="14sp"
        android:textColor="@color/text_hint" />

    <RelativeLayout
        android:id="@+id/layout_stats"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_below="@id/tv_location"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="35dp"
        android:background="@drawable/stats_bar_bg"
        android:elevation="8dp">

        <TextView
            android:id="@+id/tv_orders_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:text="@string/stat_orders_label"
            android:textColor="@color/text_on_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_orders_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_orders_label"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="4dp"
            android:text="@string/stat_orders_value"
            android:textColor="@color/text_on_primary"
            android:textSize="14sp" />


        <View
            android:id="@+id/stats_divider1"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_toStartOf="@id/tv_orders_label"
            android:layout_marginEnd="20dp"
            android:layout_marginVertical="15dp"
            android:background="@color/stat_divider" />

        <TextView
            android:id="@+id/tv_balance_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/stats_divider1"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/stat_balance_label"
            android:textColor="@color/text_on_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_balance_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_balance_label"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/stats_divider1"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/stat_balance_value"
            android:textColor="@color/text_on_primary"
            android:textSize="14sp" />


        <View
            android:id="@+id/stats_divider2"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_toEndOf="@id/tv_orders_label"
            android:layout_marginStart="20dp"
            android:layout_marginVertical="15dp"
            android:background="@color/stat_divider" />

        <TextView
            android:id="@+id/tv_total_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_toEndOf="@id/stats_divider2"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/stat_total_spent_label"
            android:textColor="@color/text_on_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_total_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_total_label"
            android:layout_alignParentEnd="true"
            android:layout_toEndOf="@id/stats_divider2"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/stat_total_spent_value"
            android:textColor="@color/text_on_primary"
            android:textSize="14sp" />

    </RelativeLayout>
    <TextView
        android:id="@+id/tv_personalInfo"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_below="@id/layout_stats"
        android:layout_marginTop="30dp"
        android:layout_marginHorizontal="35dp"
        android:text="@string/menu_personal_info"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_person"
        android:drawablePadding="12dp" />

    <TextView
        android:id="@+id/tv_yourOrder"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_below="@id/tv_personalInfo"
        android:layout_marginHorizontal="35dp"
        android:text="@string/menu_your_order"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_shopping_bag"
        android:drawablePadding="12dp" />

    <TextView
        android:id="@+id/tv_favourites"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:layout_below="@id/tv_yourOrder"
        android:layout_marginHorizontal="35dp"
        android:text="@string/menu_favourites"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_heart"
        android:drawablePadding="12dp" />

    <TextView
        android:id="@+id/tv_payment"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_below="@id/tv_favourites"
        android:layout_marginHorizontal="35dp"
        android:text="@string/menu_payment"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_payment"
        android:drawablePadding="12dp" />

    <TextView
        android:id="@+id/tv_recommended"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_below="@id/tv_payment"
        android:layout_marginHorizontal="35dp"
        android:text="@string/menu_recommended"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_recommended"
        android:drawablePadding="12dp" />

    <TextView
        android:id="@+id/tv_nearestShop"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_below="@id/tv_recommended"
        android:layout_marginHorizontal="35dp"
        android:text="@string/menu_nearest_shop"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_location"
        android:drawablePadding="12dp" />

    <TextView
        android:id="@+id/tv_logout"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_below="@id/tv_nearestShop"
        android:layout_marginHorizontal="35dp"
        android:text="@string/menu_logout"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_logout"
        android:drawablePadding="12dp" />


    <RelativeLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="33dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bottom_nav_bar">


        <ImageButton
            android:id="@+id/btn_home"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_home"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_home" />

        <ImageButton
            android:id="@+id/btn_cart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btn_profile"
            android:layout_marginEnd="10dp"
            android:src="@drawable/ic_cart"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_cart" />

        <ImageButton
            android:id="@+id/btn_notifications"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btn_home"
            android:layout_toStartOf="@id/btn_cart"
            android:layout_centerHorizontal="true"
            android:src="@drawable/ic_notifications"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_notifications" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_profile"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="8dp"
            android:paddingHorizontal="14dp"
            android:background="@drawable/nav_profile_bg"
            android:text="@string/nav_profile"
            android:textColor="@color/text_on_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:drawableStart="@drawable/ic_person_white"
            android:drawablePadding="5dp"
            android:gravity="center"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </RelativeLayout>

</RelativeLayout>
